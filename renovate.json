{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>luzifer/renovate-config"
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "github.com/Luzifer/ots/pkg/**"
      ]
    },
    {
      "matchFileNames": [
        "docker-compose.yml"
      ],
      "pinDigests": false
    }
  ]
}